# Django 配置
DEBUG=True
SECRET_KEY=your-secret-key-here

# 数据库配置
DATABASE_URL=sqlite:///db.sqlite3

# 允许的主机
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS 配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API验证控制
# 是否开启API验证，设置为False则所有API接口无需验证
# 开发环境可以设置为False方便测试，生产环境建议设置为True
ENABLE_API_AUTHENTICATION=True

# 日志级别
LOG_LEVEL=INFO

# 文章扫描配置
# 是否启用自动文章扫描
ARTICLE_SCAN_ENABLED=True
# 扫描间隔（秒），默认180秒（3分钟）
ARTICLE_SCAN_INTERVAL=180
# 生成文章目录路径
ARTICLE_GENERATED_DIR=generated_articles
# 存储文章的静态目录路径
ARTICLE_STATIC_DIR=static/file
# 扫描后文件处理方式：delete(删除) 或 move(移动到Back文件夹)，默认为move
SCANNED_FILE_ACTION=move
# 是否在扫描时忽略Back目录，默认为True
IGNORE_BACK_DIRECTORY=True